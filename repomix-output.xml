                  <Skeleton className="h-5 w-48" />
                  <Skeleton className="h-5 w-16 ml-auto" />
                  <Skeleton className="h-8 w-24" />
                </div>
              ))}
            </div>
          </CardContent>
        </Card>
      </div>
    );
  }

  if (!session) return null;

  return (
    <div className="space-y-6">
